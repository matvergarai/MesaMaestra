{
  "name": "mesa-maestra",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "doc": "compodoc -p tsconfig.json -d documentation --disableGraph --disableCoverage",
    "doc:serve": "compodoc -p tsconfig.json -d documentation -s --disableGraph --disableCoverage",
    "firebase:seed": "node scripts/generar-seed-firebase.mjs",
    "firebase:login": "firebase login",
    "firebase:deploy-rules": "firebase deploy --only database",
    "firebase:import-seed": "firebase database:set / firebase/database.seed.json --force",
    "firebase:fix-juegos": "node scripts/reparar-juegos-firebase.mjs",
    "firebase:setup": "powershell -ExecutionPolicy Bypass -File scripts/configurar-firebase.ps1",
    "docker:build": "docker build -t mesa-maestra .",
    "docker:run": "docker run --rm -p 8080:80 mesa-maestra",
    "api": "json-server --watch db.json --port 3000",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "bootstrap": "^5.3.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.0",
    "@compodoc/compodoc": "^2.0.0",
    "firebase-tools": "^15.23.0",
    "jsdom": "^28.0.0",
    "json-server": "^1.0.0-beta.15",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
